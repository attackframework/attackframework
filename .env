# ----------------------------
# Data Volumes
# ----------------------------

 # Change me!
#DATA_VOLUME_ROOT=/mnt/docker/attackframework-data
DATA_VOLUME_ROOT=d:\attackframework-data

# ----------------------------
# OpenSearch Environment Vars
# ----------------------------

CLUSTER_NAME=opensearch-cluster
COMPOSE_PROJECT_NAME=attackframework
NODE_NAME=opensearch
# Use opensearch.url so OpenSearch is always referenced by this name (alias on opensearch service).
OPENSEARCH_PUBLISH_HOST=opensearch.url

OPENSEARCH_JAVA_OPTS=-Xms8g -Xmx16g -Dopensearch.transport.cname_in_publish_address=true
OPENSEARCH_VERSION=3.5.0

DISABLE_INSTALL_DEMO_CONFIG=false
DISABLE_SECURITY_PLUGIN=false

# ----------------------------
# Admin / Dashboards passwords
# ----------------------------
# On first run, start.sh prompts for the initial OpenSearch admin password,
# passes it only for bootstrap (OPENSEARCH_INITIAL_ADMIN_PASSWORD),
# and then unsets it. This stack does not store the plaintext password.
# OpenSearch stores only the password hash in its own data.
# On later runs, start.sh prompts again via stdin and validates the password before starting Dashboards,
# because Dashboards must authenticate to OpenSearch at each container startup.

# ----------------------------
# Networking
# ----------------------------
# Note: These values are used by compose and the respective containers.
# Single source of truth is .env.

OPENSEARCH_DIAGNOSTICS_PORT=9600

OPENSEARCH_BIND_ADDRESS=0.0.0.0
#OPENSEARCH_BIND_ADDRESS=127.0.0.1
OPENSEARCH_PORT=9200

OPENSEARCH_DASHBOARDS_BIND_ADDRESS=0.0.0.0
#OPENSEARCH_DASHBOARDS_BIND_ADDRESS=127.0.0.1
OPENSEARCH_DASHBOARDS_PORT=5601
